---

---

<section class="relative overflow-hidden py-16">
  <!-- Gradient Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary via-secondary to-accent opacity-90">
  </div>

  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,currentColor_1px,transparent_0)] bg-[length:24px_24px]"
    >
    </div>
  </div>

  <div class="container relative mx-auto px-4 text-center">
    <div class="mx-auto max-w-2xl">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">
        Tetap Update dengan Berita Tech Terbaru
      </h2>
      <p class="mb-8 text-lg leading-relaxed text-white/90">
        Dapatkan berita harian tentang AI, cloud computing, cybersecurity, dan teknologi terbaru
        langsung ke inbox Anda.
      </p>

      <div class="mx-auto flex max-w-md flex-col gap-4 sm:flex-row">
        <input
          type="email"
          placeholder="Masukkan email Anda..."
          class="flex-1 rounded-lg border-0 px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-white/50"
        />
        <button class="btn-primary bg-white font-semibold text-primary shadow-lg hover:bg-white/90">
          Berlangganan
        </button>
      </div>

      <p class="mt-4 text-sm text-white/70">✨ Gratis! Tidak ada spam, unsubscribe kapan saja.</p>
    </div>
  </div>
</section>

<style>
  /* Enhanced gradient animation */
  @keyframes gradient-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .bg-gradient-to-br {
    background-size: 200% 200%;
    animation: gradient-shift 8s ease infinite;
  }

  /* Dark mode adjustments */
  :global(.dark) .bg-gradient-to-br {
    opacity: 0.95;
  }
</style>
