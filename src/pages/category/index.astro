---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Derive the category list from actual posts rather than introspecting the
// Zod schema (collections.posts.schema is a factory fn, not a Zod object, so
// .shape was undefined and threw under static prerender).
const posts = await getCollection('posts');
const categories = [...new Set(posts.map((post) => post.data.category))].sort();

const title = 'All Categories';
const description = 'Browse posts by category.';
---

<Layout title={title} description={description}>
  <main class="container mx-auto px-4 py-8">
    <h1 class="mb-8 text-4xl font-bold">{title}</h1>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        categories.map((category) => (
          <a
            href={`/category/${category.toLowerCase()}`}
            class="block rounded-lg border border-gray-200 p-6 shadow-md transition-shadow duration-300 hover:shadow-lg dark:border-gray-700 dark:bg-gray-800"
          >
            <h2 class="mb-2 text-2xl font-semibold">{category}</h2>
            <p class="text-gray-600 dark:text-gray-400">View all posts in {category} category.</p>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
